# Targenix.uz — environment variable template
# Copy to `.env` (local) or set in Railway Variables (production).
# Generated from a scan of every `process.env.*` reference in server/, client/, shared/.
# REQUIRED = boot fails without it (see server/_core/validateEnv.ts).
# OPTIONAL = code falls back to a default or feature is disabled.

# ─── Platform (Railway injects these automatically; set NODE_ENV locally) ─────
NODE_ENV=development                       # REQUIRED. "production" enables stricter checks.
PORT=3000                                  # OPTIONAL. Railway injects; web auto-picks free port.
HOSTNAME=                                  # OPTIONAL. Set by Node/Railway, read for logging only.
RAILWAY_GIT_COMMIT_SHA=                    # OPTIONAL. Used as Sentry release tag.
RAILWAY_REPLICA_ID=                        # OPTIONAL. Used in logs to identify which replica wrote.

# ─── App identity ─────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000              # REQUIRED. Must be https:// in production.
APP_BASE_URL=                              # OPTIONAL. Load-bearing for generic OAuth redirect URIs
                                           # (server/oauth/providers/generic.provider.ts) — distinct
                                           # from APP_URL; not an alias.
OWNER_OPEN_ID=                             # OPTIONAL. User openId auto-promoted to admin role on signin.
OWNER_NAME=                                # OPTIONAL. Display name for the owner account.

# ─── Database (MySQL via mysql2 / Drizzle) ────────────────────────────────────
# Provide ONE of MYSQL_PUBLIC_URL / MYSQL_URL / DATABASE_URL. TCP URLs preferred.
# Railway plugin auto-sets DATABASE_URL to a UNIX socket — code prefers TCP.
DATABASE_URL=mysql://user:pass@localhost:3306/targenix
MYSQL_PUBLIC_URL=                          # OPTIONAL. Railway public TCP URL (preferred by web+worker).
MYSQL_URL=                                 # OPTIONAL. Railway internal TCP URL (fallback).
DB_POOL_LIMIT=20                           # OPTIONAL. mysql2 connectionLimit (default 20).

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_URL=                                 # REQUIRED in production. Worker process aborts boot without it.
                                           # In dev, omit to fall back to in-process lead dispatch.

# ─── Auth (custom JWT in cookie + bcrypt) ─────────────────────────────────────
JWT_SECRET=replace-with-32+chars-random    # REQUIRED. Must be ≥32 chars. Used as JWT HS256 secret.
ENCRYPTION_KEY=replace-with-exactly-32chr  # REQUIRED. EXACTLY 32 chars. Weak/placeholder values rejected.
                                           # Rotating this BREAKS every stored Facebook token / API key.

# ─── Facebook (lead-ads webhook + login + Graph API) ──────────────────────────
FACEBOOK_APP_ID=                           # OPTIONAL on server (validated); REQUIRED for OAuth flows.
FACEBOOK_APP_SECRET=replace-me             # REQUIRED. Used to verify webhook HMAC + exchange OAuth code.
FACEBOOK_VERIFY_TOKEN=replace-me           # REQUIRED. Webhook verification token (you choose any string).
VITE_FACEBOOK_APP_ID=                      # OPTIONAL (client). Drives Facebook SDK init in the browser.

# ─── Google OAuth (Sheets / Drive integration) ────────────────────────────────
GOOGLE_CLIENT_ID=                          # OPTIONAL. Required for Sheets connections.
GOOGLE_CLIENT_SECRET=                      # OPTIONAL. Required for Sheets connections.
GOOGLE_CALLBACK_URL=                       # OPTIONAL. e.g. https://<APP_URL>/api/oauth/google/callback

# ─── Telegram (bot delivery + linking) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                        # OPTIONAL. Required for Telegram destination delivery.
TELEGRAM_BOT_USERNAME=                     # OPTIONAL. Bot @handle, used in deep-link URLs.
TELEGRAM_WEBHOOK_SECRET=                   # OPTIONAL. Telegram webhook signature secret.

# ─── Email (nodemailer SMTP — password reset / notifications) ─────────────────
SMTP_HOST=                                 # OPTIONAL. Without these, password reset emails are no-op.
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── "Forge" built-in API (internal Anthropic / OpenAI wrapper) ───────────────
BUILT_IN_FORGE_API_URL=                    # OPTIONAL. Server-side AI calls.
BUILT_IN_FORGE_API_KEY=                    # OPTIONAL. Pair with BUILT_IN_FORGE_API_URL.
VITE_FRONTEND_FORGE_API_URL=               # OPTIONAL (client). Client-side AI calls; included in CSP.
VITE_FRONTEND_FORGE_API_KEY=               # OPTIONAL (client).

# ─── Client analytics (custom endpoint, not PostHog/GA) ───────────────────────
VITE_ANALYTICS_ENDPOINT=                   # OPTIONAL. Client analytics POST target; added to CSP.
VITE_ANALYTICS_WEBSITE_ID=                 # OPTIONAL. Site id sent with each event.

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=                                # OPTIONAL. Without it Sentry init is a no-op.
SENTRY_RELEASE=                            # OPTIONAL. Falls back to RAILWAY_GIT_COMMIT_SHA[:12].
SENTRY_TRACES_SAMPLE_RATE=0.1              # OPTIONAL. Default 0.1. Keep ≤ 0.2 in production.

# ─── Worker tuning ────────────────────────────────────────────────────────────
START_WORKER=false                         # OPTIONAL. true = run worker embedded in web process (single-service mode).
WORKER_CONCURRENCY=                        # OPTIONAL. BullMQ worker parallel job count.
WORKER_HEALTH_PORT=8080                    # OPTIONAL. Worker /health port when PORT not set.
RETRY_CONCURRENCY=                         # OPTIONAL. Order retry scheduler parallelism.
RETRY_RATE_PER_SEC=                        # OPTIONAL. Order retry scheduler throttle.
RETRY_ORDER_TICK_BATCH=                    # OPTIONAL. Batch size per retry tick.
LEAD_RETRY_BACKOFF_MS=                     # OPTIONAL. Lead enrichment retry base backoff.
ORDER_RETRY_BACKOFF_MS=                    # OPTIONAL. Order delivery retry base backoff.
WORKFLOW_FIRE_MAX_CONCURRENT=              # OPTIONAL. Workflow executor concurrency cap.

# ─── Feature flags ────────────────────────────────────────────────────────────
ENABLE_LEAD_POLLING=false                  # OPTIONAL. Enables Zapier-style 10-min FB poll fallback.
CB_ENFORCEMENT=                            # OPTIONAL. Circuit-breaker enforcement mode (e.g. "off", "shadow", "enforce").
CB_ALERT_TELEGRAM_CHAT_ID=                 # OPTIONAL. Chat id for circuit-breaker alerts.
DESTINATION_SCHEDULES_ENABLED=false        # OPTIONAL. Yuboraman parity PR 4/4 Phase B. When "true", leads arriving at paused destinations are queued in destination_pending_leads and dispatched at sendHour. When "false", the pause check is bypassed and dispatch runs unchanged (Phase A behaviour).
FB_TOKEN_REFRESH_ENABLED=false             # OPTIONAL. When "true", the scheduler refreshes facebook_accounts user tokens 14d before expiry (Phase 2A). Default false so we can deploy dark, observe a no-op boot in Railway, then flip on.
FB_TOKEN_REFRESH_CONCURRENCY=3             # OPTIONAL. Parallel FB /oauth/access_token calls per tick. 3 is comfortable below any documented rate limit.
FB_TOKEN_REFRESH_AHEAD_DAYS=14             # OPTIONAL. Refresh threshold — tokens expiring within this many days are queued. 14 gives 7d of slack for scheduler outages.

# ─── Debug flags (TEMPORARY — most can be removed) ────────────────────────────
OAUTH_DEBUG=                               # OPTIONAL.
BRAND_ICON_LOG=                            # OPTIONAL.
METRICS_LOG=                               # OPTIONAL.
TYPE_VALIDATION_LOG=                       # OPTIONAL.
