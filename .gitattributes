# Force LF line endings for text files to prevent Windows CRLF test failures.
# Background: Without this, Windows clones with core.autocrlf=true convert
# .ts/.json/.sql/etc. to CRLF in the working tree, which breaks source-grep
# tests that use \n-anchored regex.

# Default: detect text files and normalize to LF on commit + checkout
* text=auto eol=lf

# Source files — explicitly LF
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sh        text eol=lf

# Lock files — also LF (npm/pnpm/yarn)
package-lock.json   text eol=lf
pnpm-lock.yaml      text eol=lf
yarn.lock           text eol=lf

# Binary files — leave alone, don't normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary

# Windows batch / PowerShell — CRLF is the convention there
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
