{
  "name": "facebook-lead-ads-webhook",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:worker": "cross-env NODE_ENV=development tsx watch server/workers/run.ts",
    "build": "tsc --noEmit && vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && esbuild server/workers/run.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/worker.js",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:worker": "cross-env NODE_ENV=production node dist/worker.js",
    "check": "tsc --noEmit",
    "check:bundle-size": "node tooling/check-bundle-size.mjs",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "db:railway:migrate": "railway run node tooling/drizzle/backfill-migration-journal-0026-0027.mjs && railway run pnpm exec drizzle-kit migrate",
    "db:sync:railway-to-local": "node tooling/mysql/full-sync.mjs",
    "db:backfill:crm-final": "tsx tooling/mysql/backfill-crm-status-final.ts",
    "crm:sync:100k": "tsx tooling/run-100k-crm-sync-once.ts"
  },
